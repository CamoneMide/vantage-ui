# =============================================================================
# VantageUI — .gitignore
# Monorepo: pnpm + Plasmo (Chrome Extension) + Next.js (Landing Page)
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit real values
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Allow the example template to be committed
!.env.example

# -----------------------------------------------------------------------------
# Node / pnpm
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Plasmo / Chrome Extension Build Outputs
# -----------------------------------------------------------------------------
.plasmo/
build/
dist/
*.crx
*.pem

# -----------------------------------------------------------------------------
# Next.js (Landing Page)
# -----------------------------------------------------------------------------
.next/
out/
.vercel/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
tsconfig.tsbuildinfo

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Vitest
# -----------------------------------------------------------------------------
/test-results/
/playwright-report/

# -----------------------------------------------------------------------------
# OS Artifacts
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Editor Artifacts
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Keep shared editor config files (formatting rules, extensions)
!.vscode/extensions.json
!.vscode/tasks.json
